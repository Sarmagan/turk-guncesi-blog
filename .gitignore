# build output
dist/
.astro/

# image optimizer outputs (regenerated by `npm run prebuild` via sharp).
# Naming convention "<orig>.<ext>.avif|webp" keeps these patterns from
# colliding with hand-authored .webp sources.
public/**/*.jpg.avif
public/**/*.jpeg.avif
public/**/*.png.avif
public/**/*.webp.avif
public/**/*.jpg.webp
public/**/*.jpeg.webp
public/**/*.png.webp
src/data/image-manifest.json

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# env files
.env
.env.production
.env.local

# editor / OS
.DS_Store
.vscode/
.idea/
*.swp
