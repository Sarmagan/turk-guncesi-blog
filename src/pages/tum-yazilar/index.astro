---
import BaseLayout from '@layouts/BaseLayout.astro';
import SocialIcons from '@components/SocialIcons.astro';
import { SITE } from '@lib/config';
import { getAllSeries } from '@lib/series';

const featuredSeries =
  getAllSeries().find((s) => s.slug === 'anadolunun-turklesmesi') ?? null;

const B = '/media/tum-yazilar';
const ART = '/tum-yazilar';

// Curated 3-column grid matching the editorial layout on the WP archive.
// Each tile links to the post's permalink.
const grid = [
  [
    {
      href: `${ART}/anadoludaki-genetik-turk-mirasi-dna-verileri-isiginda-bir-inceleme/`,
      title: 'Anadolu’daki Genetik Türk Mirası: DNA Verileri Işığında Bir İnceleme',
      image: `${B}/anadolu-dna.png`,
      alt: 'Anadolu nüfusunun genetik dağılım grafiği',
    },
    {
      href: `${ART}/istanbulun-fethinde-gemilerin-karadan-yurutulmesi-hadisesi/`,
      title: 'İstanbul’un Fethinde Gemilerin Karadan Yürütülmesi Hadisesi',
      image: `${B}/gemiler-karadan.jpg`,
      alt: 'Gemilerin Haliç’e karadan indirilmesini betimleyen tablo',
    },
    {
      href: `${ART}/emine-isinsunun-kaleminden-dis-turkler/`,
      title: 'Emine Işınsu’nun Kaleminden Dış Türkler',
      image: `${B}/emine-isinsu.jpg`,
      alt: 'Yazar Emine Işınsu portresi',
    },
  ],
  [
    {
      href: `${ART}/la-mediterranee-et-le-monde-mediterraneen-a-lepoque-de-philippe-ii-turkler-ile-alakali-ilginc-notlar/`,
      title:
        '“La Méditerranée et le monde méditerranéen à l’époque de Philippe II”: Türkler ile Alakalı İlginç Notlar',
      image: `${B}/portolan-mediterranee.jpg`,
      alt: 'François Ollive’in 1662 tarihli Akdeniz portolan haritası',
    },
    {
      href: `${ART}/buyuk-kartalin-olumu-ve-sonrasi/`,
      title: 'Büyük Kartal’ın Ölümü ve Sonrası',
      image: `${B}/fatih-bellini.jpg`,
      alt: 'Gentile Bellini’nin Fatih Sultan Mehmed portresi',
    },
    {
      href: `${ART}/kani-karaca/`,
      title: 'Kâni Karaca',
      image: `${B}/kani-karaca.jpeg`,
      alt: 'Kâni Karaca portresi',
    },
  ],
  [
    {
      href: `${ART}/turk-folklorunda-benzer-korkular-hortlak-cadi-gulyabani-ve-vampir/`,
      title:
        'Türk Folklorunda Benzer Korkular, Farklı İsimler: Hortlak, Cadı, Gulyabani ve Vampir',
      image: `${B}/gulyabani.png`,
      alt: 'Türk folklorunda gulyabani tasviri',
    },
    {
      href: `${ART}/turk-gencliginde-oz-nefret/`,
      title: 'Türk Gençliğinde Öz Nefret',
      image: `${B}/shattered-mirror.webp`,
      alt: 'Kırılmış bir aynada yansıyan Türk kültürü unsurları',
    },
    {
      href: `${ART}/osmanli-ve-turkluk/`,
      title: 'Osmanlı ve Türklük',
      image: `${B}/jon-turkler.png`,
      alt: 'Jön Türkler dönemine ait görsel',
    },
  ],
  [
    {
      href: `${ART}/turk-halk-edebiyatinda-bir-ekol-karacaoglan/`,
      title: 'Türk Halk Edebiyatında Bir Ekol: Karacaoğlan',
      image: `${B}/karacaoglan-baglama.png`,
      alt: 'Kırda bağlama çalan bir adam tasviri',
    },
    {
      href: `${ART}/orta-anadoluda-bir-yoruk-turkmen-asireti-boynuinceliler/`,
      title: 'Orta Anadolu’da bir Yörük Türkmen Aşireti: Boynuinceliler',
      image: `${B}/yoruk-cocuklari.jpeg`,
      alt: 'Yörük çocukları fotoğrafı',
    },
    {
      href: `${ART}/ramazan-ozel-osmanli-istanbulunda-ramazan-aylari/`,
      title: 'Ramazan Özel: Osmanlı İstanbul’unda Ramazan Ayları',
      image: `${B}/orta-oyunu.jpg`,
      alt: 'Mehmet Muazzez Özduygu’nun Orta Oyunu tablosu',
    },
  ],
  [
    {
      href: `${ART}/kerkuk-ezgileri/`,
      title: 'Kerkük Ezgileri',
      image: `${B}/kerkuk.jpg`,
      alt: 'Kerkük’ten bir manzara',
    },
    {
      href: `${ART}/orta-asyadan-anadoluya-kadim-turk-gelenegi-han-yagmasi/`,
      title: 'Orta Asya’dan Anadolu’ya Kadim Türk Geleneği: Han Yağması',
      image: `${B}/sunnet-dugunu.jpg`,
      alt: 'Şehzade Mehmed’in sünnet düğününden bir sahne',
    },
    {
      href: `${ART}/1402den-1922ye/`,
      title: '1402’den 1922’ye',
      image: `${B}/amir-temur.jpg`,
      alt: 'Emir Timur heykeli',
    },
  ],
];
---

<BaseLayout
  title="Tüm Yazılar"
  description="Tarihten kültüre, Türklüğe dair her şey — Türk Güncesi'nin yazı arşivi."
  fullBleed
>
  {/* ---------------- Hero cover ---------------- */}
  <section class="archive-hero" aria-labelledby="archive-hero-title">
    <img
      class="archive-hero__bg"
      src={`${B}/hero-bozkir.jpg`}
      alt=""
      width="1536"
      height="864"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="archive-hero__scrim" aria-hidden="true"></div>
    <div class="archive-hero__inner container">
      <h1 id="archive-hero-title" class="archive-hero__title">
        Tarihten Kültüre,<br />Türklüğe Dair Her Şey
      </h1>
      <p class="archive-hero__lede">
        Bu bölümde, Türklüğün tarihine, kültürüne ve düşünce dünyasına dair
        kaleme aldığımız yazıları bulabilirsiniz. Geçmişten bugüne bir iz
        sürüyoruz.
      </p>
    </div>
  </section>

  {/* ---------------- Feature 1 — Türk Modernleşmesi ---------------- */}
  <section class="feature feature--cream" aria-labelledby="feature-modernlesme">
    <div class="feature__inner container">
      <p class="feature__kicker">Türk Güncesi 101 Serisi</p>
      <h2 id="feature-modernlesme" class="feature__hero-title">
        Türk Modernleşmesi,<br />Ulus-Devlet, Türkçülük<br />ve Kemalizm
      </h2>

      <div class="feature__row">
        <p class="feature__col-text">
          Türkiye Cumhuriyeti’nin ikinci yüzyılına girdiği bu süreçte,
          post-modern dünya düzeninin yeniden şekillendiği konjonktürde
          ülkenin uluslararası arenadaki konumunu güçlendirmesi ve etkisini
          artırması için kapsamlı yeni siyasi paradigmaların geliştirilmesi
          elzem görünmektedir. Bu bağlamda, 19. yüzyıldan itibaren başlayan,
          cumhuriyetin tesisiyle hız kazanan ve ulus-devlet yapılanması
          çerçevesinde Kemalist devrimlerle doruk noktasına ulaşan Türk
          modernleşme ve Batılılaşma sürecinin derinlemesine analiz edilmesi
          ve doğru biçimde kavranması hayati önem taşımaktadır.
        </p>

        <figure class="feature__col-figure feature__col-figure--tall">
          <img
            src={`${B}/ziya-gokalp.jpg`}
            alt="Ziya Gökalp portresi"
            loading="lazy"
            decoding="async"
            width="663"
            height="1024"
          />
        </figure>

        <figure class="feature__col-figure">
          <img
            src={`${B}/namik-kemal.jpg`}
            alt="Namık Kemal portresi"
            loading="lazy"
            decoding="async"
            width="500"
            height="589"
          />
        </figure>
      </div>

      <div class="feature__row feature__row--flip">
        <figure class="feature__col-figure feature__col-figure--wide">
          <img
            src={`${B}/ataturk-tbmm.jpg`}
            alt="Atatürk TBMM'den çıkarken"
            loading="lazy"
            decoding="async"
            width="1024"
            height="725"
          />
        </figure>

        <div class="feature__col-text">
          <p>
            Bu çalışma, Cumhuriyet’in Mustafa Kemal Atatürk liderliğinde
            eğitim, ulaşım, sağlık ve iktisat gibi muhtelif alanlarda
            gerçekleştirdiği yapısal dönüşümlerden ziyade, Tanzimat Fermanı
            ile resmî bir zemine oturan Türk Batılılaşma hareketini
            inceleyecek ve bir asır sonra dahi toplumun geniş kesimleri
            tarafından yeterince idrak edilememiş olan ulus-devlet konsepti
            ile cumhuriyetin tesis ettiği yeni Türk kimliği tanımını ele
            alacaktır.
          </p>
          <a
            class="feature__cta"
            href="/tum-yazilar/turk-guncesi-101-turk-modernlesmesi-ulus-devlet-turkculuk-ve-kemalizm/"
          >
            <strong>Devamını oku</strong>
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* ---------------- Feature 2 — Divanü Lügati't Türk ---------------- */}
  <section class="cover cover--gold" aria-labelledby="cover-divan">
    <img
      class="cover__bg"
      src={`${B}/kasgarli-harita.png`}
      alt=""
      loading="lazy"
      decoding="async"
      width="1024"
      height="873"
    />
    <div class="cover__scrim cover__scrim--gold" aria-hidden="true"></div>
    <div class="cover__inner container">
      <h2 id="cover-divan" class="cover__title">
        Türk Güncesi 101 Serisi:<br />Divanü Lügati’t Türk
      </h2>
      <a class="btn btn--outline-light" href="/tum-yazilar/turk-guncesi-101-divanu-lugatit-turk/">
        Keşfet
      </a>
    </div>
  </section>

  {/* ---------------- Feature 3 — 3 Mayıs 1944 ---------------- */}
  <section class="cover cover--dark" aria-labelledby="cover-1944">
    <img
      class="cover__bg cover__bg--top"
      src={`${B}/atsiz.jpg`}
      alt=""
      loading="lazy"
      decoding="async"
      width="546"
      height="383"
    />
    <div class="cover__scrim cover__scrim--dark" aria-hidden="true"></div>
    <div class="cover__inner container cover__inner--bottom">
      <h2 id="cover-1944" class="cover__title cover__title--caps">
        Türk Milliyetçiliğinde Dönüm Noktası:<br />
        3 Mayıs 1944 ve Irkçılık-Turancılık Davası
      </h2>
      <a
        class="btn btn--outline-light"
        href="/tum-yazilar/turk-milliyetciliginde-donum-noktasi-3-mayis-1944-irkcilik-turancilik-davasi/"
      >
        <strong>Keşfet</strong>
      </a>
    </div>
  </section>

  {/* ---------------- 3-column grid ---------------- */}
  <section class="archive-grid" aria-label="Yazı arşivi">
    <div class="container">
      {grid.map((row) => (
        <div class="archive-grid__row">
          {row.map((card) => (
            <a class="archive-tile" href={card.href}>
              <span class="archive-tile__media">
                <img
                  src={card.image}
                  alt={card.alt}
                  loading="lazy"
                  decoding="async"
                />
              </span>
              <h3 class="archive-tile__title">{card.title}</h3>
            </a>
          ))}
        </div>
      ))}
    </div>
  </section>

  {/* ---------------- Anadolu'nun Türkleşmesi split ---------------- */}
  {featuredSeries && (
    <section class="series-split" aria-labelledby="series-split-title">
      <div class="series-split__text">
        <h2 id="series-split-title" class="series-split__title">
          <a href={`/tum-yazilar/${featuredSeries.slug}/`}>
            Türk Güncesi Özel: Anadolu’nun Türkleşmesi Yazı Dizisi
          </a>
        </h2>
        <p class="series-split__desc">{featuredSeries.description}</p>
        <a class="btn btn--primary" href={`/tum-yazilar/${featuredSeries.slug}/`}>
          Yazı dizisini incele →
        </a>
      </div>
      <a
        class="series-split__media"
        href={`/tum-yazilar/${featuredSeries.slug}/`}
        aria-hidden="true"
        tabindex="-1"
      >
        <img
          src={`${B}/cacabey.jpg`}
          alt=""
          loading="lazy"
          decoding="async"
          width="768"
          height="1024"
        />
      </a>
    </section>
  )}

  {/* ---------------- Contact footer ---------------- */}
  <section class="archive-contact" aria-label="İletişim">
    <div class="container">
      <p class="archive-contact__text">
        Sorularınız mı var?<br />Bize ulaşmaktan çekinmeyin.
      </p>
      <p class="archive-contact__email">
        <a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a>
      </p>
      <div class="archive-contact__social">
        <SocialIcons />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* =====================================================================
   * Archive page — matches the editorial WP "tum-yazilar" layout.
   * Uses full-bleed sections with .container-constrained copy inside.
   * ===================================================================== */

  /* ------- Hero cover ------- */
  .archive-hero {
    position: relative;
    min-height: min(78vh, 760px);
    display: flex;
    align-items: flex-end;
    color: #fff;
    overflow: hidden;
    isolation: isolate;
  }

  .archive-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -2;
  }

  .archive-hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.1) 0%,
      rgba(0, 0, 0, 0.15) 40%,
      rgba(0, 0, 0, 0.55) 100%
    );
    z-index: -1;
  }

  .archive-hero__inner {
    padding: 4rem 1.25rem 3.5rem;
    max-width: var(--max-width);
  }

  .archive-hero__title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5vw + 0.5rem, 4rem);
    line-height: 1.08;
    letter-spacing: -0.015em;
    margin: 0 0 1rem;
    color: #fff;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
  }

  .archive-hero__lede {
    font-size: clamp(1rem, 0.6vw + 0.95rem, 1.15rem);
    max-width: 42rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.92);
    margin: 0;
  }

  /* ------- Shared feature/cover buttons ------- */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.85rem 1.6rem;
    border-radius: 2px;
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid transparent;
    transition:
      background 160ms ease,
      color 160ms ease,
      border-color 160ms ease,
      transform 160ms ease;
  }

  .btn--primary {
    background: var(--accent);
    color: #fff;
  }
  .btn--primary:hover {
    background: var(--accent-hover);
    color: #fff;
    text-decoration: none;
  }

  .btn--outline-light {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.9);
    background: transparent;
    padding: 1rem 2.2rem;
  }
  .btn--outline-light:hover {
    background: rgba(255, 255, 255, 0.95);
    color: #111;
    text-decoration: none;
  }

  /* ------- Feature 1 (cream) ------- */
  .feature--cream {
    background: #f5eac1;
    color: #111;
    padding: clamp(3rem, 6vw, 6rem) 0;
  }

  .feature__inner {
    max-width: var(--max-width);
    padding: 0 1.25rem;
  }

  .feature__kicker {
    margin: 0 0 1rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #333;
  }

  .feature__hero-title {
    font-family: var(--font-serif);
    margin: 0 0 2.5rem;
    color: #111;
    font-size: clamp(2rem, 5.5vw, 5rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.01em;
  }

  .feature__row {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr 0.9fr;
    gap: clamp(1.25rem, 3vw, 2.5rem);
    align-items: center;
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
  }

  .feature__row--flip {
    grid-template-columns: 1.4fr 1fr;
    margin-bottom: 0;
  }

  .feature__col-text {
    font-size: clamp(1rem, 0.4vw + 1rem, 1.25rem);
    line-height: 1.55;
    color: #1b1b1b;
  }

  .feature__col-text p {
    margin: 0 0 1rem;
  }

  .feature__col-figure {
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .feature__col-figure img {
    display: block;
    max-width: 100%;
    height: auto;
    object-fit: contain;
    max-height: 460px;
  }

  .feature__col-figure--tall img {
    max-height: 520px;
  }

  .feature__col-figure--wide img {
    max-height: 480px;
    width: 100%;
    object-fit: cover;
    border-radius: 2px;
  }

  .feature__cta {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    background: var(--accent);
    color: #fff !important;
    border-radius: 2px;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    letter-spacing: 0.06em;
    margin-top: 0.25rem;
    text-decoration: none !important;
    transition: background 160ms ease;
  }
  .feature__cta:hover {
    background: var(--accent-hover);
  }

  @media (max-width: 820px) {
    .feature__row,
    .feature__row--flip {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .feature__col-figure img {
      max-height: 360px;
    }
  }

  /* ------- Full-bleed covers (Divanü Lügati & 3 Mayıs) ------- */
  .cover {
    position: relative;
    min-height: min(82vh, 780px);
    display: flex;
    overflow: hidden;
    isolation: isolate;
    color: #fff;
  }

  .cover__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -2;
  }

  .cover__bg--top {
    object-position: 50% 22%;
  }

  .cover__scrim {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .cover__scrim--gold {
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.2) 0%, rgba(0, 0, 0, 0.55) 100%),
      rgba(204, 173, 125, 0.45);
    mix-blend-mode: normal;
  }

  .cover__scrim--dark {
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.25) 0%,
      rgba(0, 0, 0, 0.55) 55%,
      rgba(0, 0, 0, 0.85) 100%
    );
  }

  .cover__inner {
    position: relative;
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 4rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    justify-content: center;
    align-items: flex-start;
  }

  .cover__inner--bottom {
    justify-content: flex-end;
    padding-bottom: 4rem;
  }

  .cover--gold .cover__inner {
    align-items: center;
    text-align: center;
  }

  .cover__title {
    font-family: var(--font-serif);
    margin: 0;
    font-size: clamp(2rem, 4.5vw + 0.5rem, 4rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: #fff;
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.35);
  }

  .cover--gold .cover__title {
    color: #ffe074;
  }

  .cover__title--caps {
    text-transform: uppercase;
    font-weight: 700;
    line-height: 1.08;
    max-width: 50rem;
  }

  /* ------- 3-column grid ------- */
  .archive-grid {
    background: var(--bg);
    padding: clamp(3rem, 5vw, 4.5rem) 0;
  }

  .archive-grid__row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 3vw, 3rem);
    padding: clamp(1.5rem, 3vw, 2.5rem) 0;
    border-bottom: 1px solid var(--border);
  }

  .archive-grid__row:last-child {
    border-bottom: 0;
  }

  .archive-tile {
    display: block;
    color: var(--text);
    text-decoration: none;
  }

  .archive-tile:hover {
    text-decoration: none;
  }

  .archive-tile__media {
    display: block;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--surface);
    border-radius: 2px;
    margin-bottom: 1rem;
  }

  .archive-tile__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease;
  }

  .archive-tile:hover .archive-tile__media img,
  .archive-tile:focus-visible .archive-tile__media img {
    transform: scale(1.03);
  }

  .archive-tile__title {
    font-family: var(--font-serif);
    margin: 0;
    font-size: clamp(1.05rem, 0.6vw + 0.95rem, 1.3rem);
    line-height: 1.3;
    color: var(--text);
    transition: color 140ms ease;
  }

  .archive-tile:hover .archive-tile__title,
  .archive-tile:focus-visible .archive-tile__title {
    color: var(--accent);
  }

  @media (max-width: 900px) {
    .archive-grid__row {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .archive-grid__row {
      grid-template-columns: 1fr;
    }
  }

  /* ------- Series split ------- */
  .series-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: min(100vh, 720px);
    background: var(--surface);
    color: var(--text);
  }

  .series-split__text {
    align-self: center;
    padding: clamp(2rem, 6vw, 5rem) clamp(1.5rem, 6vw, 5rem);
  }

  .series-split__title {
