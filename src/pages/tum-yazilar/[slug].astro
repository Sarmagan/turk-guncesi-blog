---
import BaseLayout from '@layouts/BaseLayout.astro';
import type { PostEntry } from '@lib/content';
import {
  getAllPosts,
  getPostBySlug,
  stripHtml,
  formatDateTR,
  enhancePostHtml,
} from '@lib/content';
import type { Series } from '@lib/series';
import { getAllSeries, getSeriesBySlug } from '@lib/series';

/**
 * Root-level dynamic route. Handles both individual posts and
 * editorial "yazı dizileri" (article series) under the same slug
 * namespace, so URLs stay flat.
 */
export async function getStaticPaths() {
  const series = getAllSeries();
  const posts = await getAllPosts();

  const seriesPaths = series.map((s) => ({
    params: { slug: s.slug },
    props: { kind: 'series' as const, series: s },
  }));

  const seriesSlugs = new Set(series.map((s) => s.slug));
  const postPaths = posts
    .filter((p) => !seriesSlugs.has(p.data.slug))
    .map((post) => ({
      params: { slug: post.data.slug },
      props: { kind: 'post' as const, post },
    }));

  return [...seriesPaths, ...postPaths];
}

type Props =
  | { kind: 'post'; post: PostEntry }
  | { kind: 'series'; series: Series };

const props = Astro.props as Props;

let seriesItems: Array<{
  entry: Series['entries'][number];
  post: PostEntry | null;
}> = [];

if (props.kind === 'series') {
  seriesItems = await Promise.all(
    props.series.entries.map(async (entry) => {
      const post = await getPostBySlug(entry.slug);
      return { entry, post };
    }),
  );
}

const post = props.kind === 'post' ? props.post : null;
const postData = post?.data;

const title =
  props.kind === 'series'
    ? `${props.series.title} — ${props.series.kicker}`
    : stripHtml(postData!.title, 160);

const description =
  props.kind === 'series'
    ? stripHtml(props.series.description, 200)
    : stripHtml(postData!.excerpt || postData!.content, 200);

const heroImage =
  props.kind === 'post' && postData?.featuredImage
    ? { url: postData.featuredImage, alt: postData.featuredImageAlt || '' }
    : null;
---

{
  props.kind === 'series' ? (
    <BaseLayout title={title} description={description} fullBleed>
      {props.series.hero && (
        <section
          class="series-hero"
          style={`background-image: url('${props.series.hero.image}')`}
          aria-label={props.series.title}
        >
          <div class="series-hero__scrim" aria-hidden="true" />
          <div class="series-hero__inner">
            <h1 class="series-hero__headline">
              {props.series.hero.headline}
            </h1>
            {props.series.hero.credit && (
              <p class="series-hero__credit">{props.series.hero.credit}</p>
            )}
            <p class="series-hero__tag">#turkguncesi</p>
          </div>
        </section>
      )}

      {props.series.quote && (
        <section class="series-quote">
          {props.series.quote.image && (
            <img
              class="series-quote__portrait"
              src={props.series.quote.image}
              alt={props.series.quote.imageAlt || ''}
              width="150"
              height="150"
              loading="eager"
              decoding="async"
            />
          )}
          <blockquote class="series-quote__text">
            <p>{props.series.quote.text}</p>
            {props.series.quote.cite && (
              <cite>
                — {props.series.quote.cite}
                {props.series.quote.citeRole && (
                  <>
                    , <em>{props.series.quote.citeRole}</em>
                  </>
                )}
              </cite>
            )}
          </blockquote>
        </section>
      )}

      {props.series.intro && (
        <section class="series-intro">
          <div class="series-intro__inner">
            <header class="series-intro__header">
              <h2 class="series-intro__title">{props.series.intro.title}</h2>
              <hr class="series-intro__rule" />
            </header>
            <div class="series-intro__columns">
              {props.series.intro.paragraphs.map((p) => (
                <p>{p}</p>
              ))}
            </div>
          </div>
        </section>
      )}

      <section class="series-entries" aria-label="Dizi yazıları" id="yazilar">
        {seriesItems.map(({ entry, post: seriesPost }, i) => {
          const href = seriesPost ? `/tum-yazilar/${seriesPost.data.slug}` : '#';
          const itemTitle =
            entry.label ?? seriesPost?.data.title ?? entry.slug;
          const mediaRight = i % 2 === 0;
          return (
            <article
              class={`series-row${mediaRight ? ' series-row--media-right' : ''}`}
            >
              <a class="series-row__media" href={href} tabindex="-1" aria-hidden="true">
                <img
                  src={entry.image}
                  alt={entry.imageAlt || ''}
                  loading={i < 2 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </a>
              <div class="series-row__body">
                <h2 class="series-row__title">
                  <a href={href}>
                    <strong>
                      Yazı {entry.order}: <span set:html={itemTitle} />
                    </strong>
                  </a>
                </h2>
                <p class="series-row__blurb">{entry.blurb}</p>
              </div>
            </article>
          );
        })}
      </section>

      {props.series.outro && (
        <section class="series-intro series-intro--outro">
          <div class="series-intro__inner">
            <header class="series-intro__header">
              <h2 class="series-intro__title">{props.series.outro.title}</h2>
              <hr class="series-intro__rule" />
            </header>
            <div class="series-intro__columns">
              {props.series.outro.paragraphs.map((p) => (
                <p>{p}</p>
              ))}
            </div>
          </div>
        </section>
      )}

      <footer class="series-footer container">
        <a class="series-footer__back" href="/tum-yazilar/">
          ← Tüm yazılara dön
        </a>
      </footer>
    </BaseLayout>
  ) : (
    <BaseLayout
      title={title}
      description={description}
      image={heroImage?.url ?? undefined}
      type="article"
      publishedTime={postData!.date}
      modifiedTime={postData!.modified || postData!.date}
      author={postData!.author.name}
    >
      <article class="post">
        <header class="post__header">
          {postData!.categories.length > 0 && (
            <p class="post__kicker">
              {postData!.categories.map((c, i) => (
                <>
                  {i > 0 && <span aria-hidden="true"> · </span>}
                  <span>{c.name}</span>
                </>
              ))}
            </p>
          )}
          <h1 set:html={postData!.title} />
          <p class="post__meta">
            <span>{postData!.author.name}</span>
            <span aria-hidden="true">·</span>
            <time datetime={postData!.date}>
              {formatDateTR(postData!.date)}
            </time>
          </p>
        </header>

        {heroImage && (
          <figure class="post__hero">
            <img
              src={heroImage.url}
              alt={heroImage.alt}
              loading="eager"
              decoding="async"
            />
            {heroImage.alt && <figcaption>{heroImage.alt}</figcaption>}
          </figure>
        )}

        <div class="post-body post__body" set:html={enhancePostHtml(postData!.content)} />

        <footer class="post__footer">
          <a class="post__back" href="/tum-yazilar/">
            ← Tüm yazılara dön
          </a>
        </footer>
      </article>
    </BaseLayout>
  )
}

<style>
  /* ---------------- post ---------------- */
  .post {
    max-width: 44rem;
    margin: 0 auto;
    padding: 2rem 1.25rem 3rem;
  }

  .post__header {
    text-align: left;
    margin-bottom: 1.5rem;
  }

  .post__kicker {
    margin: 0 0 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .post__header h1 {
    margin: 0 0 0.75rem;
    line-height: 1.2;
  }

  .post__meta {
    font-family: var(--font-sans);
    font-size: 0.88rem;
    color: var(--text-muted);
    margin: 0;
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .post__hero {
    margin: 1.5rem 0 2rem;
  }

  .post__hero img {
    width: 100%;
    border-radius: var(--radius);
  }

  .post__footer {
    margin-top: 3rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
    font-family: var(--font-sans);
    font-size: 0.95rem;
  }

  /* =================================================================
     Series page layout
     (mirrors blog.turkguncesi.com/anadolunun-turklesmesi/)
     ================================================================= */

  /* --- hero cover --- */
  .series-hero {
    position: relative;
    min-height: min(100vh, 820px);
    background-size: cover;
    background-position: center;
    color: #ffee58;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: clamp(1.5rem, 3vw, 3rem);
  }

  .series-hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.15) 0%,
      rgba(0, 0, 0, 0) 35%,
      rgba(0, 0, 0, 0) 55%,
      rgba(0, 0, 0, 0.35) 100%
    );
    pointer-events: none;
  }

  .series-hero__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    flex: 1;
    gap: 2rem;
  }

  .series-hero__headline {
    color: #ffee58;
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: clamp(3rem, 12vw, 12rem);
    line-height: 0.9;
    letter-spacing: -0.015em;
    margin: 0;
    max-width: 80%;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.55);
  }

  .series-hero__credit {
    position: absolute;
    top: 0;
    right: 0;
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    opacity: 0.95;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.6);
  }

  .series-hero__tag {
    align-self: flex-end;
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    opacity: 0.95;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.6);
  }

  /* --- portrait + quote --- */
  .series-quote {
    max-width: 44rem;
    margin: 0 auto;
    padding: 3rem 1.25rem 1.5rem;
    text-align: center;
  }

  .series-quote__portrait {
    width: 150px;
    height: 150px;
    border-radius: 999px;
    object-fit: cover;
    display: inline-block;
    margin-bottom: 1.5rem;
    background: var(--surface);
  }

  .series-quote__text {
    margin: 0;
    padding: 0;
    border: 0;
    font-family: var(--font-serif);
  }

  .series-quote__text p {
    font-size: clamp(1.2rem, 1.6vw + 0.8rem, 1.75rem);
    line-height: 1.4;
    font-style: italic;
    margin: 0 0 1rem;
    white-space: pre-line;
  }

  .series-quote__text cite {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--text-muted);
    font-style: normal;
  }

  .series-quote__text cite em {
    font-style: italic;
  }

  /* --- intro band (Giriş) --- */
  .series-intro {
    background: #f2f0e9;
    color: #111;
    padding: 4rem 1.25rem;
  }

  html[data-theme='dark'] .series-intro {
    background: #23221e;
    color: var(--text);
  }

  .series-intro__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .series-intro__header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .series-intro__title {
    margin: 0;
    font-family: var(--font-serif);
    text-align: center;
    font-weight: 700;
    font-size: clamp(1.2rem, 1vw + 1rem, 1.75rem);
  }

  .series-intro__rule {
    border: 0;
    border-top: 2px solid currentColor;
    opacity: 0.9;
    margin: 0;
    width: 100%;
  }

  .series-intro__columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.25rem;
  }

  .series-intro__columns p {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.65;
    color: inherit;
  }

  @media (max-width: 720px) {
    .series-intro__header {
      grid-template-columns: 1fr;
    }
    .series-intro__rule {
      display: none;
    }
    .series-intro__columns {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }

  /* --- alternating media-text rows --- */
  .series-entries {
    max-width: var(--max-width);
    margin: 3.5rem auto;
    padding: 0 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  .series-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 2.5rem;
  }

  .series-row--media-right .series-row__media {
    order: 2;
  }

  .series-row--media-right .series-row__body {
    order: 1;
    text-align: left;
  }

  .series-row__media {
    display: block;
    overflow: hidden;
    border-radius: var(--radius);
    background: var(--surface);
    transition: transform 220ms ease, box-shadow 220ms ease;
  }

  .series-row__media img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    transition: transform 400ms ease;
  }

  .series-row:hover .series-row__media img,
  .series-row:focus-within .series-row__media img {
    transform: scale(1.03);
  }

  .series-row__body {
    min-width: 0;
    text-align: center;
  }

  .series-row:not(.series-row--media-right) .series-row__body {
    text-align: left;
  }

  .series-row__title {
    margin: 0 0 0.8rem;
    font-family: var(--font-serif);
    font-size: clamp(1.35rem, 1.2vw + 1rem, 1.9rem);
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .series-row__title a {
    color: var(--text);
  }

  .series-row__title a:hover,
  .series-row__title a:focus-visible {
    color: var(--accent);
    text-decoration: none;
  }

  .series-row__blurb {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.55;
    font-size: clamp(0.9rem, 0.3vw + 0.85rem, 1.02rem);
  }

  @media (max-width: 780px) {
    .series-row {
      grid-template-columns: 1fr;
      gap: 1.1rem;
    }
    .series-row--media-right .series-row__media,
    .series-row--media-right .series-row__body {
      order: initial;
    }
    .series-row__body,
    .series-row:not(.series-row--media-right) .series-row__body {
      text-align: left;
    }
  }

  /* --- footer --- */
  .series-footer {
    margin: 1.5rem auto 3rem;
    text-align: center;
    font-family: var(--font-sans);
    font-size: 0.95rem;
  }
</style>
