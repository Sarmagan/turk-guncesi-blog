---
import BaseLayout from '@layouts/BaseLayout.astro';
import type { PostEntry } from '@lib/content';
import {
  getAllPosts,
  getPostBySlug,
  stripHtml,
  formatDateTR,
  enhancePostHtml,
  readingTimeMinutes,
  getAdjacentPosts,
} from '@lib/content';
import { SITE } from '@lib/config';
import type { Series } from '@lib/series';
import { getAllSeries, getSeriesBySlug } from '@lib/series';

/**
 * Root-level dynamic route. Handles both individual posts and
 * editorial "yazı dizileri" (article series) under the same slug
 * namespace, so URLs stay flat.
 */
export async function getStaticPaths() {
  const series = getAllSeries();
  const posts = await getAllPosts();

  const seriesPaths = series.map((s) => ({
    params: { slug: s.slug },
    props: { kind: 'series' as const, series: s },
  }));

  const seriesSlugs = new Set(series.map((s) => s.slug));
  const postPaths = posts
    .filter((p) => !seriesSlugs.has(p.data.slug))
    .map((post) => ({
      params: { slug: post.data.slug },
      props: { kind: 'post' as const, post },
    }));

  return [...seriesPaths, ...postPaths];
}

type Props =
  | { kind: 'post'; post: PostEntry }
  | { kind: 'series'; series: Series };

const props = Astro.props as Props;

let seriesItems: Array<{
  entry: Series['entries'][number];
  post: PostEntry | null;
}> = [];

if (props.kind === 'series') {
  seriesItems = await Promise.all(
    props.series.entries.map(async (entry) => {
      const post = await getPostBySlug(entry.slug);
      return { entry, post };
    }),
  );
}

const post = props.kind === 'post' ? props.post : null;
const postData = post?.data;

const title =
  props.kind === 'series'
    ? `${props.series.title} — ${props.series.kicker}`
    : stripHtml(postData!.title, 160);

const description =
  props.kind === 'series'
    ? stripHtml(props.series.description, 200)
    : stripHtml(postData!.excerpt || postData!.content, 200);

const heroImage =
  props.kind === 'post' && postData?.featuredImage
    ? { url: postData.featuredImage, alt: postData.featuredImageAlt || '' }
    : null;

const allPostsForAdjacency =
  props.kind === 'post' ? await getAllPosts() : [];
const { previous: previousPost, next: nextPost } =
  props.kind === 'post'
    ? getAdjacentPosts(allPostsForAdjacency, postData!.slug)
    : { previous: null, next: null };

const readingMinutes =
  props.kind === 'post' ? readingTimeMinutes(postData!.content) : 0;

const postUrl =
  props.kind === 'post'
    ? new URL(`/tum-yazilar/${postData!.slug}/`, SITE.url).toString()
    : '';
const shareTitleRaw = props.kind === 'post' ? stripHtml(postData!.title, 160) : '';
const shareTitle = encodeURIComponent(shareTitleRaw);
const shareUrlEnc = encodeURIComponent(postUrl);
const breadcrumbs =
  props.kind === 'post'
    ? [
        { name: 'Ana sayfa', url: new URL('/', SITE.url).toString() },
        { name: 'Tüm Yazılar', url: new URL('/tum-yazilar/', SITE.url).toString() },
        { name: shareTitleRaw, url: postUrl },
      ]
    : [];
---

{
  props.kind === 'series' ? (
    <BaseLayout title={title} description={description} fullBleed>
      {props.series.hero && (
        <section
          class="series-hero"
          style={`background-image: url('${props.series.hero.image}')`}
          aria-label={props.series.title}
        >
          <div class="series-hero__scrim" aria-hidden="true" />
          <div class="series-hero__inner">
            <h1 class="series-hero__headline">
              {props.series.hero.headline}
            </h1>
            {props.series.hero.credit && (
              <p class="series-hero__credit">{props.series.hero.credit}</p>
            )}
            <p class="series-hero__tag">#turkguncesi</p>
          </div>
        </section>
      )}

      {props.series.quote && (
        <section class="series-quote">
          {props.series.quote.image && (
            <img
              class="series-quote__portrait"
              src={props.series.quote.image}
              alt={props.series.quote.imageAlt || ''}
              width="150"
              height="150"
              loading="eager"
              decoding="async"
            />
          )}
          <blockquote class="series-quote__text">
            <p>{props.series.quote.text}</p>
            {props.series.quote.cite && (
              <cite>
                — {props.series.quote.cite}
                {props.series.quote.citeRole && (
                  <>
                    , <em>{props.series.quote.citeRole}</em>
                  </>
                )}
              </cite>
            )}
          </blockquote>
        </section>
      )}

      {props.series.intro && (
        <section class="series-intro">
          <div class="series-intro__inner">
            <header class="series-intro__header">
              <h2 class="series-intro__title">{props.series.intro.title}</h2>
              <hr class="series-intro__rule" />
            </header>
            <div class="series-intro__columns">
              {props.series.intro.paragraphs.map((p) => (
                <p>{p}</p>
              ))}
            </div>
          </div>
        </section>
      )}

      <section class="series-entries" aria-label="Dizi yazıları" id="yazilar">
        {seriesItems.map(({ entry, post: seriesPost }, i) => {
          const href = seriesPost ? `/tum-yazilar/${seriesPost.data.slug}` : '#';
          const itemTitle =
            entry.label ?? seriesPost?.data.title ?? entry.slug;
          const mediaRight = i % 2 === 0;
          return (
            <article
              class={`series-row${mediaRight ? ' series-row--media-right' : ''}`}
            >
              <a class="series-row__media" href={href} tabindex="-1" aria-hidden="true">
                <img
                  src={entry.image}
                  alt={entry.imageAlt || ''}
                  loading={i < 2 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </a>
              <div class="series-row__body">
                <h2 class="series-row__title">
                  <a href={href}>
                    <strong>
                      Yazı {entry.order}: <span set:html={itemTitle} />
                    </strong>
                  </a>
                </h2>
                <p class="series-row__blurb">{entry.blurb}</p>
              </div>
            </article>
          );
        })}
      </section>

      {props.series.outro && (
        <section class="series-intro series-intro--outro">
          <div class="series-intro__inner">
            <header class="series-intro__header">
              <h2 class="series-intro__title">{props.series.outro.title}</h2>
              <hr class="series-intro__rule" />
            </header>
            <div class="series-intro__columns">
              {props.series.outro.paragraphs.map((p) => (
                <p>{p}</p>
              ))}
            </div>
          </div>
        </section>
      )}

      <footer class="series-footer container">
        <a class="series-footer__back" href="/tum-yazilar/">
          ← Tüm yazılara dön
        </a>
      </footer>
    </BaseLayout>
  ) : (
    <BaseLayout
      title={title}
      description={description}
      image={heroImage?.url ?? undefined}
      type="article"
      publishedTime={postData!.date}
      modifiedTime={postData!.modified || postData!.date}
      author={postData!.author.name}
      breadcrumbs={breadcrumbs}
    >
      <div class="reading-progress" aria-hidden="true">
        <div class="reading-progress__bar" id="reading-progress-bar"></div>
      </div>

      <article
        class="post"
        data-pagefind-body
        data-pagefind-filter="kind:Yazı"
      >
        <header class="post__header">
          {postData!.categories.length > 0 && (
            <p class="post__kicker">
              {postData!.categories.map((c, i) => (
                <>
                  {i > 0 && <span aria-hidden="true"> · </span>}
                  <span>{c.name}</span>
                </>
              ))}
            </p>
          )}
          <h1 set:html={postData!.title} />
          <p class="post__meta">
            <span>{postData!.author.name}</span>
            <span aria-hidden="true">·</span>
            <time datetime={postData!.date}>
              {formatDateTR(postData!.date)}
            </time>
            <span aria-hidden="true">·</span>
            <span class="post__reading-time">{readingMinutes} dk okuma</span>
          </p>
        </header>

        {heroImage && (
          <figure class="post__hero">
            <img
              src={heroImage.url}
              alt={heroImage.alt}
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
            {heroImage.alt && <figcaption>{heroImage.alt}</figcaption>}
          </figure>
        )}

        <div class="post-body post__body" set:html={enhancePostHtml(postData!.content)} />

        <section class="post-share" aria-label="Bu yazıyı paylaş" data-pagefind-ignore>
          <h2 class="post-share__title">Paylaş</h2>
          <ul class="post-share__list">
            <li>
              <a
                class="post-share__btn"
                href={`https://x.com/intent/tweet?url=${shareUrlEnc}&text=${shareTitle}`}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="X'te paylaş"
              >
                X
              </a>
            </li>
            <li>
              <a
                class="post-share__btn"
                href={`https://bsky.app/intent/compose?text=${shareTitle}%20${shareUrlEnc}`}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Bluesky'da paylaş"
              >
                Bluesky
              </a>
            </li>
            <li>
              <a
                class="post-share__btn"
                href={`https://api.whatsapp.com/send?text=${shareTitle}%20${shareUrlEnc}`}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="WhatsApp'ta paylaş"
              >
                WhatsApp
              </a>
            </li>
            <li>
              <a
                class="post-share__btn"
                href={`mailto:?subject=${shareTitle}&body=${shareUrlEnc}`}
                aria-label="E-posta ile paylaş"
              >
                E-posta
              </a>
            </li>
            <li>
              <button
                type="button"
                class="post-share__btn post-share__copy"
                data-copy-url={postUrl}
                aria-label="Bağlantıyı kopyala"
              >
                <span class="post-share__copy-label">Bağlantıyı kopyala</span>
                <span class="post-share__copy-feedback" aria-hidden="true">Kopyalandı</span>
              </button>
            </li>
          </ul>
        </section>

        {(previousPost || nextPost) && (
          <nav class="post-nav" aria-label="Yazı gezintisi" data-pagefind-ignore>
            {previousPost ? (
              <a class="post-nav__link post-nav__link--prev" href={`/tum-yazilar/${previousPost.data.slug}/`}>
                <span class="post-nav__direction">← Önceki yazı</span>
                <span class="post-nav__title" set:html={previousPost.data.title} />
              </a>
            ) : (
              <span />
            )}
            {nextPost ? (
              <a class="post-nav__link post-nav__link--next" href={`/tum-yazilar/${nextPost.data.slug}/`}>
                <span class="post-nav__direction">Sonraki yazı →</span>
                <span class="post-nav__title" set:html={nextPost.data.title} />
              </a>
            ) : (
              <span />
            )}
          </nav>
        )}

        <footer class="post__footer" data-pagefind-ignore>
          <a class="post__back" href="/tum-yazilar/">
            ← Tüm yazılara dön
          </a>
        </footer>
      </article>

      <button
        type="button"
        class="back-to-top"
        id="back-to-top"
        aria-label="Sayfanın başına dön"
        hidden
      >
        ↑
      </button>

      <script is:inline>
        (() => {
          const bar = document.getElementById('reading-progress-bar');
          const btn = document.getElementById('back-to-top');
          const article = document.querySelector('.post');
          if (!bar || !article) return;

          const prefersReduced =
            window.matchMedia &&
            window.matchMedia('(prefers-reduced-motion: reduce)').matches;

          let ticking = false;
          const update = () => {
            ticking = false;
            const rect = article.getBoundingClientRect();
            const total = rect.height - window.innerHeight;
            const scrolled = Math.min(
              Math.max(-rect.top, 0),
              Math.max(total, 1),
            );
            const pct = total > 0 ? (scrolled / total) * 100 : 0;
            bar.style.width = pct + '%';
            if (btn) {
              if (window.scrollY > 600) {
                btn.hidden = false;
              } else {
                btn.hidden = true;
              }
            }
          };

          const onScroll = () => {
            if (ticking) return;
            ticking = true;
            window.requestAnimationFrame(update);
          };

          window.addEventListener('scroll', onScroll, { passive: true });
          window.addEventListener('resize', onScroll);
          update();

          if (btn) {
            btn.addEventListener('click', () => {
              window.scrollTo({
                top: 0,
                behavior: prefersReduced ? 'auto' : 'smooth',
              });
            });
          }

          const copyBtn = document.querySelector('.post-share__copy');
          if (copyBtn) {
            copyBtn.addEventListener('click', async () => {
              const url = copyBtn.getAttribute('data-copy-url') || window.location.href;
              try {
                await navigator.clipboard.writeText(url);
              } catch {
                const ta = document.createElement('textarea');
                ta.value = url;
                ta.setAttribute('readonly', '');
                ta.style.position = 'absolute';
                ta.style.left = '-9999px';
                document.body.appendChild(ta);
                ta.select();
                try { document.execCommand('copy'); } catch {}
                document.body.removeChild(ta);
              }
              copyBtn.classList.add('post-share__copy--done');
              setTimeout(() => {
                copyBtn.classList.remove('post-share__copy--done');
              }, 1800);
            });
          }
        })();
      </script>
    </BaseLayout>
  )
}

<style>
  /* ---------------- post ---------------- */
  .post {
    max-width: 44rem;
    margin: 0 auto;
    padding: 2rem 1.25rem 3rem;
  }

  .post__header {
    text-align: left;
    margin-bottom: 1.5rem;
  }

  .post__kicker {
    margin: 0 0 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .post__header h1 {
    margin: 0 0 0.75rem;
    line-height: 1.2;
  }

  .post__meta {
    font-family: var(--font-sans);
    font-size: 0.88rem;
    color: var(--text-muted);
    margin: 0;
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .post__hero {
    margin: 1.5rem 0 2rem;
  }

  .post__hero img {
    width: 100%;
    border-radius: var(--radius);
  }

  .post__footer {
    margin-top: 3rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
    font-family: var(--font-sans);
    font-size: 0.95rem;
  }

  .post__reading-time {
    font-variant-numeric: tabular-nums;
  }

  /* Reading progress bar pinned below the sticky header */
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    z-index: 30;
    background: transparent;
    pointer-events: none;
  }

  .reading-progress__bar {
    height: 100%;
    width: 0%;
    background: var(--accent);
    transition: width 80ms linear;
  }

  @media (prefers-reduced-motion: reduce) {
    .reading-progress__bar {
      transition: none;
    }
  }

  /* Share + copy-link row */
  .post-share {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .post-share__title {
    margin: 0 0 0.75rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-weight: 600;
  }

  .post-share__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .post-share__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.85rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-elevated);
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 0.88rem;
    cursor: pointer;
    transition:
      border-color 120ms ease,
      color 120ms ease,
      background 120ms ease;
  }

  .post-share__btn:hover,
  .post-share__btn:focus-visible {
    border-color: var(--accent);
    color: var(--accent);
    text-decoration: none;
  }

  .post-share__copy {
    position: relative;
  }

  .post-share__copy-feedback {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    background: var(--bg-elevated);
    color: var(--accent);
    border-radius: var(--radius);
  }

  .post-share__copy--done .post-share__copy-feedback {
    display: flex;
  }

  /* Previous / next navigation */
  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .post-nav__link {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-elevated);
    color: var(--text);
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .post-nav__link:hover,
  .post-nav__link:focus-visible {
    text-decoration: none;
    border-color: var(--accent);
    box-shadow: var(--shadow-card);
    transform: translateY(-1px);
  }

  .post-nav__link--next {
    text-align: right;
  }

  .post-nav__direction {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .post-nav__title {
    font-family: var(--font-serif);
    font-size: 1.02rem;
    line-height: 1.35;
    color: var(--text);
  }

  @media (max-width: 600px) {
    .post-nav {
      grid-template-columns: 1fr;
    }
    .post-nav__link--next {
      text-align: left;
    }
  }

  /* Floating back-to-top button */
  .back-to-top {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 999px;
    background: var(--accent);
    color: #fff;
    border: 0;
    font-size: 1.2rem;
    line-height: 1;
    cursor: pointer;
    box-shadow: var(--shadow-card-strong);
    z-index: 25;
    transition: transform 160ms ease, opacity 160ms ease;
  }

  .back-to-top:hover,
  .back-to-top:focus-visible {
    transform: translateY(-2px);
  }

  .back-to-top[hidden] {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .back-to-top {
      transition: none;
    }
  }

  /* =================================================================
     Series page layout
     (mirrors blog.turkguncesi.com/anadolunun-turklesmesi/)
     ================================================================= */

  /* --- hero cover --- */
  .series-hero {
    position: relative;
    min-height: min(100vh, 820px);
    background-size: cover;
    background-position: center;
    color: #ffee58;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: clamp(1.5rem, 3vw, 3rem);
  }

  .series-hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.15) 0%,
      rgba(0, 0, 0, 0) 35%,
      rgba(0, 0, 0, 0) 55%,
      rgba(0, 0, 0, 0.35) 100%
    );
    pointer-events: none;
  }

  .series-hero__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    flex: 1;
    gap: 2rem;
  }

  .series-hero__headline {
    color: #ffee58;
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: clamp(3rem, 12vw, 12rem);
    line-height: 0.9;
    letter-spacing: -0.015em;
    margin: 0;
    max-width: 80%;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.55);
  }

  .series-hero__credit {
    position: absolute;
    top: 0;
    right: 0;
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    opacity: 0.95;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.6);
  }

  .series-hero__tag {
    align-self: flex-end;
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    opacity: 0.95;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.6);
  }

  /* --- portrait + quote --- */
  .series-quote {
    max-width: 44rem;
    margin: 0 auto;
    padding: 3rem 1.25rem 1.5rem;
    text-align: center;
  }

  .series-quote__portrait {
    width: 150px;
    height: 150px;
    border-radius: 999px;
    object-fit: cover;
    display: inline-block;
    margin-bottom: 1.5rem;
    background: var(--surface);
  }

  .series-quote__text {
    margin: 0;
    padding: 0;
    border: 0;
    font-family: var(--font-serif);
  }

  .series-quote__text p {
    font-size: clamp(1.2rem, 1.6vw + 0.8rem, 1.75rem);
    line-height: 1.4;
    font-style: italic;
    margin: 0 0 1rem;
    white-space: pre-line;
  }

  .series-quote__text cite {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--text-muted);
    font-style: normal;
  }

  .series-quote__text cite em {
    font-style: italic;
  }

  /* --- intro band (Giriş) --- */
  .series-intro {
    background: #f2f0e9;
    color: #111;
    padding: 4rem 1.25rem;
  }

  html[data-theme='dark'] .series-intro {
    background: #23221e;
    color: var(--text);
  }

  .series-intro__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .series-intro__header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .series-intro__title {
    margin: 0;
    font-family: var(--font-serif);
    text-align: center;
    font-weight: 700;
    font-size: clamp(1.2rem, 1vw + 1rem, 1.75rem);
  }

  .series-intro__rule {
    border: 0;
    border-top: 2px solid currentColor;
    opacity: 0.9;
    margin: 0;
    width: 100%;
  }

  .series-intro__columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.25rem;
  }

