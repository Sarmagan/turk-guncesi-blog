---
import type { PostEntry } from '@lib/content';
import { stripHtml, formatDateTR } from '@lib/content';

interface Props {
  post: PostEntry;
  /** Row = compact list (used on /tum-yazilar/). Card = image + excerpt. */
  variant?: 'card' | 'row';
}

const { post, variant = 'card' } = Astro.props;
const { data } = post;

const href = `/tum-yazilar/${data.slug}`;
const excerpt = stripHtml(data.excerpt, 180);
const featured = data.featuredImage
  ? { url: data.featuredImage, alt: data.featuredImageAlt || '' }
  : null;
const author = data.author.name;
const categories = data.categories.slice(0, 2);
---

<article class={`post-card post-card--${variant}`} data-post-slug={data.slug}>
  {
    featured && variant === 'card' && (
      <a href={href} class="post-card__media" aria-hidden="true" tabindex="-1">
        <img src={featured.url} alt={featured.alt} loading="lazy" decoding="async" />
      </a>
    )
  }

  <div class="post-card__body">
    {
      categories.length > 0 && (
        <p class="post-card__kicker">
          {categories.map((c, i) => (
            <>
              {i > 0 && <span aria-hidden="true"> · </span>}
              <span>{c.name}</span>
            </>
          ))}
        </p>
      )
    }

    <h2 class="post-card__title">
      <a href={href} set:html={data.title}></a>
    </h2>

    {excerpt && <p class="post-card__excerpt">{excerpt}</p>}

    <p class="post-card__meta">
      <span>{author}</span>
      <span aria-hidden="true">·</span>
      <time datetime={data.date}>{formatDateTR(data.date)}</time>
    </p>
  </div>
</article>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      border-color 160ms ease;
  }

  .post-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
    border-color: color-mix(in oklab, var(--border) 60%, var(--text) 40%);
  }

  .post-card__media {
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--surface);
  }

  .post-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post-card[data-post-slug='bir-cirpida-turkculugun-mimarlari-11-buyuk-oncu']
    .post-card__media
    img {
    object-position: 50% 18%;
  }

  .post-card__body {
    padding: 1.1rem 1.15rem 1.25rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .post-card__kicker {
    margin: 0 0 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .post-card__title {
    margin: 0 0 0.5rem;
    font-size: 1.2rem;
    line-height: 1.3;
  }

  .post-card__title a {
    color: var(--text);
  }

  .post-card__title a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .post-card__excerpt {
    color: var(--text-muted);
    font-size: 0.98rem;
    margin: 0 0 0.9rem;
  }

  .post-card__meta {
    margin: auto 0 0;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: var(--text-muted);
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .post-card--row {
    flex-direction: row;
    align-items: flex-start;
    padding: 1.1rem 0;
    border: 0;
    border-bottom: 1px solid var(--border);
    border-radius: 0;
    background: transparent;
    gap: 1.1rem;
  }

  .post-card--row:hover {
    transform: none;
    box-shadow: none;
  }

  .post-card--row .post-card__body {
    padding: 0;
  }

  .post-card--row .post-card__title {
    font-size: 1.35rem;
  }
</style>
