---
import { NAV_LINKS, SITE } from '@lib/config';
import ThemeToggle from './ThemeToggle.astro';

const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';

function isActive(href: string): boolean {
  const normalized = href.replace(/\/+$/, '') || '/';
  return currentPath === normalized;
}
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="brand" href="/" aria-label={`${SITE.name} ana sayfa`}>
      <img
        class="brand__logo"
        src="/logo.png"
        alt=""
        width="40"
        height="40"
        loading="eager"
        decoding="async"
        aria-hidden="true"
      />
      <span class="brand__text">
        <span class="brand__name">{SITE.name}</span>
      </span>
    </a>

    <div class="site-header__right">
      <form class="header-search" role="search" action="/ara/" method="get" aria-label="Site araması">
        <label class="visually-hidden" for="header-search-input">Sitede ara</label>
        <input
          id="header-search-input"
          class="header-search__input"
          type="search"
          name="q"
          placeholder="Ara…"
          autocomplete="off"
        />
        <button type="submit" class="header-search__btn" aria-label="Aramayı gönder">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2" />
            <path d="m20 20-3.5-3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
        </button>
      </form>
      <nav aria-label="Ana gezinme">
        <input id="nav-toggle" type="checkbox" class="nav-toggle" aria-label="Menüyü aç/kapat" />
        <label for="nav-toggle" class="nav-toggle__btn" aria-hidden="true">
          <span></span><span></span><span></span>
        </label>
        <ul class="nav">
          {
            NAV_LINKS.map(({ href, label }) => (
              <li>
                <a href={href} aria-current={isActive(href) ? 'page' : undefined}>
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  .site-header {
    background: var(--header-blur-bg, var(--bg-elevated));
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: saturate(140%) blur(8px);
    -webkit-backdrop-filter: saturate(140%) blur(8px);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.9rem;
    padding-bottom: 0.9rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--text);
    text-decoration: none;
  }

  .brand:hover,
  .brand:focus-visible {
    color: var(--text);
    text-decoration: none;
  }

  .brand__logo {
    display: block;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 6px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .brand__text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .brand__name {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: -0.01em;
  }

  .site-header__right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .header-search {
    position: relative;
    display: flex;
    align-items: center;
  }

  .header-search__input {
    width: 11rem;
    padding: 0.35rem 2rem 0.35rem 0.7rem;
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    color: var(--text);
    border-radius: var(--radius);
    font-family: var(--font-sans);
    font-size: 0.88rem;
    transition: border-color 140ms ease, box-shadow 140ms ease, width 160ms ease;
  }

  .header-search__input::placeholder {
    color: var(--text-muted);
  }

  .header-search__input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 2px color-mix(in oklab, var(--accent) 25%, transparent);
  }

  .header-search__btn {
    position: absolute;
    right: 0.25rem;
    top: 50%;
    transform: translateY(-50%);
    border: 0;
    background: transparent;
    padding: 0.3rem;
    color: var(--text-muted);
    cursor: pointer;
    display: inline-flex;
    border-radius: 4px;
  }

  .header-search__btn:hover,
  .header-search__btn:focus-visible {
    color: var(--accent);
  }

  @media (max-width: 820px) {
    .header-search__input {
      width: 8rem;
    }
  }

  @media (max-width: 560px) {
    .header-search__input {
      display: none;
    }
    .header-search__btn {
      position: static;
      transform: none;
      padding: 0.4rem;
      border: 1px solid var(--border);
      background: var(--bg-elevated);
      border-radius: var(--radius);
    }
    .header-search {
      margin-right: 0;
    }
  }

  nav {
    position: relative;
  }

  .nav {
    display: flex;
    gap: 1.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.95rem;
  }

  .nav a {
    color: var(--text);
    padding: 0.3rem 0.1rem;
    border-bottom: 2px solid transparent;
  }

  .nav a:hover,
  .nav a:focus-visible {
    color: var(--accent);
    text-decoration: none;
    border-bottom-color: var(--accent);
  }

  .nav a[aria-current='page'] {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  /* Mobile hamburger — CSS-only (no JS) */
  .nav-toggle {
    display: none;
  }

  .nav-toggle__btn {
    display: none;
  }

  @media (max-width: 720px) {
    .nav-toggle__btn {
      display: inline-flex;
      flex-direction: column;
      justify-content: space-between;
      width: 1.6rem;
      height: 1.2rem;
      cursor: pointer;
    }

    .nav-toggle__btn span {
      display: block;
      height: 2px;
      background: var(--text);
      border-radius: 1px;
      transition: transform 160ms ease;
    }

    .nav {
      position: absolute;
      right: 0;
      top: calc(100% + 0.75rem);
      background: var(--bg-elevated);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 0.75rem 1rem;
      flex-direction: column;
      gap: 0.75rem;
      min-width: 12rem;
      box-shadow: var(--shadow-card-strong);
      display: none;
    }

    .nav-toggle:checked ~ .nav {
      display: flex;
    }
  }
</style>
