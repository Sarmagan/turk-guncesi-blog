---
/**
 * Inline SVG icons for footer social links.
 * No external assets, no tracking — everything renders from this file.
 */
import { SOCIAL_LINKS } from '@lib/config';

const links = [
  {
    href: SOCIAL_LINKS.instagram,
    label: 'Instagram',
    icon: 'instagram',
  },
  { href: SOCIAL_LINKS.x, label: 'X (Twitter)', icon: 'x' },
  { href: SOCIAL_LINKS.bluesky, label: 'Bluesky', icon: 'bluesky' },
  { href: SOCIAL_LINKS.youtube, label: 'YouTube', icon: 'youtube' },
];
---

<ul class="social">
  {
    links.map(({ href, label, icon }) => (
      <li>
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer me"
          aria-label={label}
          title={label}
        >
          {icon === 'instagram' && (
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <rect x="3" y="3" width="18" height="18" rx="5" ry="5" fill="none" stroke="currentColor" stroke-width="1.8" />
              <circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.8" />
              <circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" />
            </svg>
          )}
          {icon === 'x' && (
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path
                d="M17.53 3H20.5l-6.52 7.45L22 21h-6.3l-4.93-6.45L5.1 21H2.13l6.98-7.98L2 3h6.43l4.46 5.9L17.53 3Zm-1.1 16.2h1.73L7.66 4.7H5.8l10.63 14.5Z"
                fill="currentColor"
              />
            </svg>
          )}
          {icon === 'bluesky' && (
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path
                d="M6.2 3.6c2.6 2 5.4 5.9 6.4 8C13.6 9.5 16.4 5.6 19 3.6c1.9-1.4 4.9-2.5 4.9 1 0 .7-.4 5.8-.6 6.6-.8 2.9-3.7 3.6-6.3 3.2 4.6.8 5.8 3.4 3.2 6-4.8 4.8-7-1.2-7.5-2.8l-.1-.2-.1.2c-.6 1.6-2.7 7.6-7.5 2.8-2.5-2.5-1.4-5.2 3.2-6-2.6.4-5.5-.3-6.3-3.2C1.7 10.4 1.3 5.3 1.3 4.6c0-3.5 3-2.4 4.9-1Z"
                fill="currentColor"
              />
            </svg>
          )}
          {icon === 'youtube' && (
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path
                d="M23.5 7.2a3 3 0 0 0-2.1-2.1C19.6 4.6 12 4.6 12 4.6s-7.6 0-9.4.5A3 3 0 0 0 .5 7.2 31.3 31.3 0 0 0 0 12a31.3 31.3 0 0 0 .5 4.8 3 3 0 0 0 2.1 2.1c1.8.5 9.4.5 9.4.5s7.6 0 9.4-.5a3 3 0 0 0 2.1-2.1A31.3 31.3 0 0 0 24 12a31.3 31.3 0 0 0-.5-4.8ZM9.6 15.6v-7.2L15.8 12l-6.2 3.6Z"
                fill="currentColor"
              />
            </svg>
          )}
        </a>
      </li>
    ))
  }
</ul>

<style>
  .social {
    display: flex;
    gap: 0.6rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    color: var(--text);
    background: var(--bg-elevated);
    transition:
      background 120ms ease,
      color 120ms ease,
      border-color 120ms ease,
      transform 120ms ease;
  }

  .social a:hover,
  .social a:focus-visible {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
    text-decoration: none;
    transform: translateY(-1px);
  }

  .social svg {
    width: 1.1rem;
    height: 1.1rem;
  }
</style>
